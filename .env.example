# ─── Samba Fête — Environment Variables ───────────────────────────
# Copy this file to .env and fill in real values.
#   cp .env.example .env

# Flask secret key (generate one: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Set to "production" when deploying (enables secure cookies)
FLASK_ENV=development

# Set to "1" to enable debug mode (NEVER in production)
FLASK_DEBUG=0

# Server port
PORT=5000

# Database URL (optional, defaults to local SQLite)
# DATABASE_URL=postgresql://user:pass@localhost:5432/samba_fete
